{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", "helpers:pinGitHubActionDigests"],
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true,
  "gitAuthor": "doxynix-deps-bot <273657142+doxynix-deps-bot[bot]@users.noreply.github.com>",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "timezone": "Europe/Moscow",
  "pinDigests": true,
  "rangeStrategy": "pin",
  "minimumReleaseAge": "3 days",
  "postUpdateOptions": ["pnpmDedupe"],
  "labels": ["dependencies"],
  "ignoreDeps": ["zod-prisma-types"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "addLabels": ["security"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "addLabels": ["minor-update"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "addLabels": ["patch-update"]
    },
    {
      "description": "Запрещаем мажорный апдейт cookie (v1 ломает совместимость с auth/sockets)",
      "matchPackageNames": ["cookie"],
      "allowedVersions": "<1.0.0"
    },
    {
      "description": "Запрещаем мажорный апдейт eslint (v10 ломает плагины React)",
      "matchPackageNames": ["eslint"],
      "allowedVersions": "<10.0.0"
    },
    {
      "description": "Группируем все минорные и патч обновления npm",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "description": "Группируем ВСЕ обновления GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions updates",
      "groupSlug": "all-actions"
    },
    {
      "matchPackageNames": ["@types/**"],
      "groupName": "all @types"
    }
  ],
  "separateMajorMinor": true,
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "automerge": false
}