{
  "name": "web",
  "version": "2.0.1",
  "engines": {
    "node": ">=v24.0.0",
    "pnpm": "11.1.1"
  },
  "license": "AGPL-3.0-only",
  "private": true,
  "lint-staged": {
    "*": [
      "secretlint"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "with-doppler": "node scripts/doppler.mjs",
    "dev": "pnpm with-doppler \"pnpm gen:credits && pnpm db:generate && cross-env NODE_OPTIONS=\\\"--max-old-space-size=4096\\\" next dev\"",
    "dev:fast": "pnpm with-doppler \"cross-env NODE_OPTIONS=\\\"--max-old-space-size=2048\\\" next dev\"",
    "dev:trace": "pnpm with-doppler \"cross-env NEXT_TURBOPACK_TRACING=1 NODE_OPTIONS=\\\"--max-old-space-size=2048\\\" next dev\"",
    "build": "pnpm with-doppler \"pnpm db:generate && next build\"",
    "start": "pnpm with-doppler \" pnpm next start\"",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint",
    "lint:changed": "lint-staged --diff=\"HEAD\"",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "analyze": "pnpm with-doppler \"cross-env ANALYZE=true next build --webpack\"",
    "analyze:exp": "pnpm with-doppler \"next experimental-analyze\"",
    "dev:analyze": "pnpm with-doppler \"cross-env ANALYZE=true next dev\"",
    "format": "prettier . --write --cache --cache-location node_modules/.cache/prettier",
    "dup": "jscpd src",
    "secretlint": "secretlint \"**/*\"",
    "secretlint:check": "secretlint \"**/*\"",
    "typecheck:coverage": "type-coverage --threshold 90",
    "knip": "pnpm with-doppler \"knip --no-exit-code\"",
    "spellcheck": "cspell \"**/*\" --no-progress --show-suggestions",
    "gen:client": "pnpm with-doppler \"openapi --input http://localhost:3000/api/openapi --output ./src/shared/api-contracts/client --client axios\"",
    "gen:credits": "node scripts/thanks.mjs",
    "doc:gen": "typedoc",
    "db:generate": "pnpm with-doppler \"zenstack generate --schema prisma/schema.zmodel && prisma generate --sql\"",
    "db:migrate": "pnpm with-doppler \"pnpm db:generate && prisma migrate dev\"",
    "db:migrate-prod": "pnpm with-doppler \"pnpm db:generate && prisma migrate deploy\"",
    "db:push": "pnpm with-doppler \"prisma db push\"",
    "db:reset": "pnpm with-doppler \"prisma migrate reset\"",
    "db:studio": "pnpm with-doppler \"prisma studio\"",
    "db:seed": "pnpm with-doppler \"pnpm db:generate && prisma db seed\"",
    "test:stryker": "pnpm with-doppler \"pnpm stryker run\"",
    "test": "pnpm with-doppler \"cross-env TZ=UTC vitest run --config vitest.config.ts --no-file-parallelism\"",
    "test:int": "pnpm with-doppler \"cross-env TZ=UTC vitest run src/tests/integration --config vitest.config.ts --no-file-parallelism\"",
    "test:unit": "pnpm with-doppler \"cross-env TZ=UTC vitest run src/tests/unit --config vitest.config.ts\"",
    "test:e2e": "pnpm with-doppler \"pnpm exec playwright test\"",
    "test:coverage": "pnpm with-doppler \"cross-env TZ=UTC vitest run --coverage --config vitest.config.ts --no-file-parallelism\"",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "changeset publish",
    "trigger": "pnpm with-doppler \"pnpm dlx trigger.dev@latest dev\"",
    "trigger:remote": "pnpm with-doppler \"pnpm dlx trigger.dev@latest deploy --env prod\"",
    "trigger:deploy": "pnpm with-doppler \"pnpm dlx trigger.dev deploy\"",
    "arch:graph-full": "depcruise src/server/features --config .dependency-cruiser.js --output-type dot | dot -T svg > arch/architecture.svg",
    "arch:graph": "depcruise src --collapse 2 --config .dependency-cruiser.js --output-type dot | dot -T svg > arch/architecture.svg",
    "arch:focus": "depcruise src/server --config .dependency-cruiser.js --output-type dot --collapse 3 --focus",
    "arch:check": "depcruise src --config .dependency-cruiser.js --output-type err",
    "arch:html": "dependency-cruiser src/server --config .dependency-cruiser.js --output-type err-html -f arch/server-report.html",
    "arch:dump": "chcp 65001 && dependency-cruiser src --config .dependency-cruiser.js --output-type dot --exclude \"^(node_modules|src/shared/api-contracts|\\.next)\" > arch/dependencies_list.txt"
  },
